#include <iostream>
using namespace std;
int main() {
    int num;
    int *ptr;
    ptr=&num;
    cout<<"Enter a number:-";
    cin>>num;
    cout<<"value :-"<<num<<endl;
    cout<<"address :-"<<&num<<endl;
    cout<<"value of pointer:-"<<ptr<<endl;
    cout<<"address:-"<<&ptr<<endl;
    cout<<"value:-"<<*ptr;
    

    return 0;
}
